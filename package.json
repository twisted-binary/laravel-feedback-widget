{
    "name": "@twisted-binary/feedback-widget",
    "version": "1.7.0",
    "description": "AI-powered feedback widget for Laravel + Inertia + Vue apps.",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "format": "prettier --write resources/js",
        "format:check": "prettier --check resources/js",
        "test": "vitest run",
