    },
    "devDependencies": {
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.1",
        "happy-dom": "^20.0.0",
        "prettier": "^3.8.1",
        "typescript": "^6.0.0",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.2.4"
    }
}
